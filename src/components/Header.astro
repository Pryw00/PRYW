---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/clientes', label: 'Clientes' },
];

const currentPath = Astro.url.pathname;
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-brand" aria-label="PRYW — Inicio">
      <span class="brand-mark">PRYW</span>
      <span class="brand-handle">@Pryw00</span>
    </a>

    <button
      class="nav-toggle"
      id="nav-toggle"
      aria-controls="primary-nav"
      aria-expanded="false"
      aria-label="Abrir menú de navegación"
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" aria-label="Navegación principal">
      <ul class="nav-list" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .header-brand {
    display: flex;
    align-items: baseline;
    gap: var(--space-xs);
    text-decoration: none;
  }

  .brand-mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: -0.04em;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .brand-handle {
    font-size: var(--text-small);
    color: #666;
    font-weight: 500;
  }

  .nav-list {
    display: flex;
    gap: var(--space-md);
    align-items: center;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-ink);
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent-purple);
    border-bottom-color: var(--color-accent-purple);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-ink);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    #primary-nav {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: white;
      border-bottom: 1px solid rgba(0,0,0,0.1);
      padding: var(--space-sm) var(--space-md);
      display: none;
    }

    #primary-nav.open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
