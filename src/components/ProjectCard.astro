---
interface Props {
  title: string;
  description: string;
  role: string;
  images?: string[];
  liveUrl?: string;
  credit: string;
  slug?: string;
}

const { title, description, role, images = [], liveUrl, credit, slug } = Astro.props;
---
<article class="project-card reveal">
  {images[0] && (
    <div class="card-image">
      <img src={images[0]} alt={`Screenshot de ${title}`} loading="lazy" width="800" height="450" />
    </div>
  )}
  {!images[0] && (
    <div class="card-image card-image--placeholder" aria-hidden="true">
      <span class="placeholder-icon">◈</span>
    </div>
  )}

  <div class="card-body">
    <h3 class="heading-display card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <p class="card-role"><strong>Rol:</strong> {role}</p>

    <footer class="card-footer">
      <p class="card-credit">{credit}</p>
      <div class="card-actions">
        {slug && (
          <a href={`/proyectos/${slug}`} class="card-link">Ver proyecto →</a>
        )}
        {liveUrl && (
          <a href={liveUrl} class="card-link card-link--external" target="_blank" rel="noopener noreferrer">
            Ver en vivo ↗
          </a>
        )}
      </div>
    </footer>
  </div>
</article>

<style>
  .project-card {
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .project-card:hover {
    box-shadow: 0 8px 32px rgba(124, 92, 252, 0.18);
    transform: translateY(-4px);
  }

  .card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-bg-light);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .project-card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-hero);
  }

  .placeholder-icon {
    font-size: 3rem;
    color: rgba(255,255,255,0.5);
  }

  .card-body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-xs);
  }

  .card-title {
    font-size: var(--text-h3);
    color: var(--color-ink);
    margin-bottom: var(--space-xs);
  }

  .card-description {
    font-size: 0.9375rem;
    color: #444;
    line-height: 1.6;
    flex: 1;
  }

  .card-role {
    font-size: var(--text-small);
    color: var(--color-accent-purple);
    font-weight: 500;
    margin-top: var(--space-xs);
  }

  .card-footer {
    margin-top: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid rgba(0,0,0,0.07);
  }

  .card-credit {
    font-size: var(--text-small);
    color: #999;
    margin-bottom: var(--space-xs);
  }

  .card-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-purple);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .card-link:hover {
    color: var(--color-accent-cyan);
  }
</style>
