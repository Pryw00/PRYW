---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout
  title="Proyectos — Wilson Yépez @Pryw00"
  description="Proyectos de desarrollo web, aplicaciones y videojuegos por Wilson Yépez — Tech Web Alchimist."
>
  <!-- Page Hero -->
  <section class="page-hero section-gradient" aria-labelledby="projects-page-heading">
    <div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="page-hero-inner">
      <p class="page-hero-label">@Pryw00</p>
      <h1 id="projects-page-heading" class="heading-display page-hero-title">Proyectos</h1>
    </div>
  </section>

  <!-- Grid -->
  <section class="projects-section" aria-labelledby="projects-page-heading">
    <div class="projects-inner">
      <div class="projects-grid">
        {sorted.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            role={project.data.role}
            images={project.data.images}
            liveUrl={project.data.liveUrl}
            credit={project.data.credit}
            slug={project.id}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    padding: var(--space-xl) var(--space-md);
    overflow: hidden;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.25);
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-hero-label {
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-bottom: var(--space-xs);
  }

  .page-hero-title {
    font-size: var(--text-h1);
    color: #fff;
  }

  .projects-section {
    padding: var(--space-xl) var(--space-md);
  }

  .projects-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-md);
  }

  @media (max-width: 480px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
