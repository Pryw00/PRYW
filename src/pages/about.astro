---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
---
<BaseLayout
  title="Sobre mí — Wilson Yépez @Pryw00"
  description="Ingeniero en Sistemas Computacionales, Magíster en Computación y Experto en Ciberseguridad. Desarrollador Web desde Ibarra, Ecuador."
>
  <!-- Page Hero -->
  <section class="page-hero section-gradient" aria-labelledby="about-page-heading">
    <div class="page-hero-overlay" aria-hidden="true"></div>
    <div class="page-hero-inner">
      <p class="page-hero-label">@Pryw00</p>
      <h1 id="about-page-heading" class="heading-display page-hero-title">Sobre mí</h1>
    </div>
  </section>

  <!-- Bio -->
  <section class="bio-section section-light" aria-labelledby="bio-heading">
    <div class="bio-inner">
      <div class="bio-text reveal">
        <h2 id="bio-heading" class="heading-display bio-heading">Wilson Yépez</h2>
        <p class="bio-subtitle">{profile.title}</p>
        <p class="bio-body">{profile.bio}</p>
        <div class="bio-contact">
          <a href={`mailto:${profile.contact.email}`}>{profile.contact.email}</a>
          <span>{profile.contact.phone}</span>
          <a href={profile.contact.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href={profile.contact.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
      <div class="bio-portrait reveal">
        <div class="portrait-frame">
          <img
            src="/images/portrait.jpg"
            alt="Wilson Yépez"
            width="480"
            height="560"
            loading="eager"
            onerror="this.style.display='none'; this.parentElement.classList.add('portrait-frame--missing')"
          />
          <div class="portrait-missing-label" aria-hidden="true">W.Y.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="edu-section" aria-labelledby="edu-heading">
    <div class="content-inner">
      <h2 id="edu-heading" class="heading-display section-heading reveal">Educación</h2>
      <ul class="edu-list" role="list">
        {profile.education.map((item) => (
          <li class="edu-item reveal">
            <span class="edu-period">{item.period}</span>
            <h3 class="edu-degree">{item.degree}</h3>
            <p class="edu-institution">{item.institution}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Training -->
  <section class="training-section section-light" aria-labelledby="training-heading">
    <div class="content-inner">
      <h2 id="training-heading" class="heading-display section-heading reveal">Capacitaciones</h2>
      <ul class="training-list" role="list">
        {profile.training.map((item) => (
          <li class="training-item reveal">
            <div class="training-meta">
              <span class="training-platform">{item.platform} · {item.year}</span>
              <span class="training-hours">{item.hours}h</span>
            </div>
            <p class="training-title">{item.title}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Experience -->
  <section class="exp-section" aria-labelledby="exp-heading">
    <div class="content-inner">
      <h2 id="exp-heading" class="heading-display section-heading reveal">Experiencia</h2>
      <ul class="exp-list" role="list">
        {profile.experience.map((item) => (
          <li class="exp-item reveal">
            <h3 class="exp-role">{item.role}</h3>
            {item.company && <p class="exp-company">{item.company}</p>}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page hero */
  .page-hero {
    position: relative;
    padding: var(--space-xl) var(--space-md);
    overflow: hidden;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.25);
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-hero-label {
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-bottom: var(--space-xs);
  }

  .page-hero-title {
    font-size: var(--text-h1);
    color: #fff;
  }

  /* Bio */
  .bio-section { padding: var(--space-xl) var(--space-md); }

  .bio-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .bio-heading {
    font-size: var(--text-h2);
    margin-bottom: var(--space-xs);
  }

  .bio-subtitle {
    font-size: 0.9375rem;
    color: var(--color-accent-purple);
    font-weight: 500;
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  .bio-body {
    font-size: var(--text-body);
    line-height: 1.75;
    color: #333;
    margin-bottom: var(--space-md);
  }

  .bio-contact {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: 0.9375rem;
  }

  .bio-contact a, .bio-contact span {
    color: var(--color-accent-purple);
    text-decoration: none;
  }

  .bio-contact a:hover { text-decoration: underline; }

  .portrait-frame {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 6/7;
    background: var(--gradient-hero);
  }

  .portrait-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }

  .portrait-frame--missing .portrait-missing-label {
    display: flex;
  }

  .portrait-missing-label {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 5rem;
    color: rgba(255,255,255,0.4);
  }

  /* Shared section styles */
  .content-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md);
  }

  .section-heading {
    font-size: var(--text-h2);
    margin-bottom: var(--space-lg);
  }

  /* Education */
  .edu-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .edu-item {
    border-left: 4px solid var(--color-accent-purple);
    padding-left: var(--space-md);
  }

  .edu-period {
    font-size: var(--text-small);
    color: var(--color-accent-cyan);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .edu-degree {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 4px 0 2px;
  }

  .edu-institution {
    font-size: 0.9375rem;
    color: #666;
  }

  /* Training */
  .training-section .content-inner { padding: var(--space-xl) var(--space-md); }

  .training-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .training-item {
    background: var(--color-paper);
    border-radius: var(--radius-md);
    padding: var(--space-sm) var(--space-md);
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .training-meta {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-small);
    color: var(--color-accent-purple);
    font-weight: 600;
    margin-bottom: 4px;
  }

  .training-title {
    font-size: 0.9375rem;
    color: var(--color-ink);
  }

  /* Experience */
  .exp-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .exp-item {
    padding: var(--space-sm) var(--space-md);
    border-left: 4px solid var(--color-accent-cyan);
    background: var(--color-bg-light);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .exp-role {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .exp-company {
    font-size: 0.9rem;
    color: #666;
    margin-top: 2px;
  }

  @media (max-width: 768px) {
    .bio-inner { grid-template-columns: 1fr; }
    .bio-portrait { order: -1; max-width: 280px; margin: 0 auto; }
  }
</style>
